# --- Data (REQUIRED in production) ---
DATABASE_URL=
GOLD_DESK_URL=http://localhost:3003

# Live market data. ALWAYS true in production (fast-mode fallbacks are dev-only).
# Local live data: npm run dev:live
DESK_LIVE_MARKETS=true

# Job auth (required in production for /api/jobs/*; Vercel cron sends CRON_SECRET as Bearer)
CRON_SECRET=
APP_WRITE_TOKEN=

# Optional LLM post-mortem narratives (tags stay rule-based)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Pro gating — off by default (early access free)
PAYWALL_ENABLED=false
EARLY_ACCESS_FREE=true
PRO_ALLOWLIST=
PRO_BYPASS_TOKEN=

# Stripe billing (needed once PAYWALL_ENABLED=true)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
NEXT_PUBLIC_APP_URL=http://localhost:3004
